# Public site metadata
NEXT_PUBLIC_DEFAULT_REGION=us
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Admin access hardening
ADMIN_METRICS_TOKEN=replace_with_long_random_string

# Airtable
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_LEADS=Leads
AIRTABLE_TABLE_EVENTS=Events

# CMS / content APIs
CMS_BASE_URL=https://cms.example.com
STRAPI_API_URL=https://strapi.example.com
STRAPI_API_TOKEN=replace_with_strapi_api_token
HYGRAPH_ENDPOINT=https://your-hygraph-endpoint
HYGRAPH_TOKEN=replace_with_hygraph_token

# Supabase / KPI services
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# Square payments
NEXT_PUBLIC_SQUARE_APPLICATION_ID=replace_with_square_application_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=replace_with_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production

# Deployment / region targeting
SITE_REGION=us
