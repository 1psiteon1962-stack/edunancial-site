# Airtable
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_LEADS=Leads
AIRTABLE_TABLE_EVENTS=Events

# Admin Metrics (used for /admin/kpi/export authentication)
ADMIN_METRICS_TOKEN=replace_with_long_random_string

# Monitoring & observability
# Optional explicit environment label (development|staging|production)
MONITORING_ENV=development
# Log level override (debug|info|warn|error)
LOG_LEVEL=debug
# If true, /api/health/ready returns 503 unless Airtable is configured
REQUIRE_AIRTABLE_FOR_READINESS=false

# Regions
NEXT_PUBLIC_DEFAULT_REGION=us
SITE_REGION=us

# SEO
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_token

# Supabase (KPI/Admin)
# Server-side Supabase URL (preferred for backend-only integrations; also accepted by the admin upload portal)
SUPABASE_URL=https://your-project.supabase.co
# Public Supabase URL (used by client-side KPI helpers; the admin upload portal accepts this as a fallback for SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CMS Integrations (only set what your deployment uses)
CMS_BASE_URL=https://your-cms.example.com
STRAPI_API_URL=https://your-strapi.example.com
STRAPI_API_TOKEN=your_strapi_api_token
HYGRAPH_ENDPOINT=https://your-hygraph-endpoint
HYGRAPH_TOKEN=your_hygraph_token

# Square Checkout
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your_square_app_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_TRIAL_MEMBERSHIP_ENABLED=false
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_NOTIFICATION_URL=https://www.edunancial.com/api/square/webhook
# Keep disabled until verified webhook processing and fulfillment are implemented.
SQUARE_VERIFIED_CHECKOUT_ENABLED=false

# Secure Edunancial Admin Content Upload Portal
# Owner-only admin account email. Must match the login address exactly.
EDUNANCIAL_ADMIN_EMAIL=owner@example.com
# Password hash format: scrypt$<salt-hex>$<hash-hex>
# Generate with: node -e "const { randomBytes, scryptSync } = require('crypto'); const p = 'change-me'; const s = randomBytes(16).toString('hex'); console.log(`scrypt$${s}$${scryptSync(p, s, 64).toString('hex')}`)"
EDUNANCIAL_ADMIN_PASSWORD_HASH=
# 32+ character server-only secret used to sign admin sessions.
EDUNANCIAL_ADMIN_SESSION_SECRET=replace_with_a_long_random_secret
# Supabase storage bucket name used by the admin portal for durable upload and export storage.
# Optional: defaults to `admin-content` when omitted. `EDUNANCIAL_UPLOAD_STORAGE_BUCKET` is also accepted.
EDUNANCIAL_UPLOAD_STORAGE_KEY=admin-content
# Optional GitHub export integration (server-only).
EDUNANCIAL_GITHUB_TOKEN=
EDUNANCIAL_GITHUB_OWNER=1psiteon1962-stack
EDUNANCIAL_GITHUB_REPO=edunancial-site
EDUNANCIAL_GITHUB_BASE_BRANCH=main
# Temporary emergency CU workbench password hash. Falls back to configured owner/admin hashes when omitted.
EDUNANCIAL_CU_PASSWORD_HASH=

# Temporary isolated Content Loader portal
EDUNANCIAL_CONTENT_LOADER_PASSWORD=replace_with_temporary_admin_password
EDUNANCIAL_CONTENT_LOADER_USERNAME=content-loader-admin
EDUNANCIAL_CONTENT_LOADER_SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars
