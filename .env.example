# Airtable
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_LEADS=Leads
AIRTABLE_TABLE_EVENTS=Events

# Admin Metrics (used for /admin/kpi/export authentication)
ADMIN_METRICS_TOKEN=replace_with_long_random_string

# Monitoring & observability
# Optional explicit environment label (development|staging|production)
MONITORING_ENV=development
# Log level override (debug|info|warn|error)
LOG_LEVEL=debug
# If true, /api/health/ready returns 503 unless Airtable is configured
REQUIRE_AIRTABLE_FOR_READINESS=false

# Regions
NEXT_PUBLIC_DEFAULT_REGION=us
SITE_REGION=us

# SEO
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_token

# Supabase (KPI/Admin + Member Auth Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CMS Integrations (only set what your deployment uses)
CMS_BASE_URL=https://your-cms.example.com
STRAPI_API_URL=https://your-strapi.example.com
STRAPI_API_TOKEN=your_strapi_api_token
HYGRAPH_ENDPOINT=https://your-hygraph-endpoint
HYGRAPH_TOKEN=your_hygraph_token

# Square Checkout
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your_square_app_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_TRIAL_MEMBERSHIP_ENABLED=false
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_NOTIFICATION_URL=https://www.edunancial.com/api/square/webhook
# Keep disabled until verified webhook processing and fulfillment are implemented.
SQUARE_VERIFIED_CHECKOUT_ENABLED=false

# ============================================================
# PRODUCTION MEMBER AUTHENTICATION
# (Added for feature/production-member-auth)
# ============================================================

# Session secret — MUST be at least 32 random characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER share or commit this value. NEVER use NEXT_PUBLIC_ prefix.
AUTH_SESSION_SECRET=replace_with_64_hex_characters_of_random_data

# Public site URL used to build email verification and password-reset links.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.edunancial.com

# Email provider: resend | sendgrid | console
# Use "console" in development to print emails to the terminal.
EMAIL_PROVIDER=console
EMAIL_FROM_ADDRESS=noreply@edunancial.com
EMAIL_FROM_NAME=Edunancial

# Resend (https://resend.com) — set EMAIL_PROVIDER=resend to activate
RESEND_API_KEY=re_your_resend_api_key

# SendGrid — set EMAIL_PROVIDER=sendgrid to activate
SENDGRID_API_KEY=SG.your_sendgrid_api_key

