# Airtable
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_LEADS=Leads
AIRTABLE_TABLE_EVENTS=Events

# Admin Metrics
ADMIN_METRICS_TOKEN=replace_with_long_random_string

# Optional Future Expansion
NEXT_PUBLIC_DEFAULT_REGION=us

# ─── API Platform ─────────────────────────────────────────────────────────────

# JWT Authentication (min 32 chars)
JWT_SECRET=replace_with_a_random_string_of_at_least_32_characters
JWT_ACCESS_TTL_S=900
JWT_REFRESH_TTL_S=604800

# API Key Authentication
API_KEY_SECRET=replace_with_a_random_string_for_api_key_hashing

# Webhook Security
WEBHOOK_INCOMING_SECRET=replace_with_webhook_shared_secret

# Rate Limiting (defaults built-in; override for custom limits)
# RATE_LIMIT_API=120
# RATE_LIMIT_AUTH=10

# ─── Integration Hub ──────────────────────────────────────────────────────────

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_ENVIRONMENT=test

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox

# Google Analytics 4 (Measurement Protocol)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret

# Google Search Console
GSC_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Microsoft Clarity
CLARITY_PROJECT_ID=your_clarity_project_id

# Email Provider: "sendgrid" | "resend" (omit for console stub)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@edunancial.com

# SMS Provider: "twilio" (omit for console stub)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555555555

# AI Provider: "openai" | "anthropic" (omit for console stub)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-haiku-20240307

# CRM Provider: "hubspot" (omit for console stub)
CRM_PROVIDER=hubspot
HUBSPOT_API_KEY=your_hubspot_private_app_token

# Accounting Provider: "quickbooks" (omit for console stub)
ACCOUNTING_PROVIDER=quickbooks
QUICKBOOKS_ACCESS_TOKEN=your_quickbooks_access_token
QUICKBOOKS_COMPANY_ID=your_quickbooks_company_id
QUICKBOOKS_ENVIRONMENT=sandbox

# Learning Provider: "teachable" (omit for internal engine)
LEARNING_PROVIDER=teachable
TEACHABLE_API_KEY=your_teachable_api_key
TEACHABLE_SCHOOL_SUBDOMAIN=yourschool

# ─── Monitoring ───────────────────────────────────────────────────────────────

# Structured logging
SERVICE_NAME=edunancial-api
LOG_LEVEL=info
