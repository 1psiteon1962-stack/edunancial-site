/*
  Content-Security-Policy: default-src 'self';
    script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.paypal.com https://www.paypalobjects.com https://code.tidio.co https://*.tidio.co;
    connect-src 'self' https://api.netlify.com https://*.paypal.com https://www.paypal.com https://www.paypalobjects.com https://*.tidio.co wss://ws.tidio.co;
    img-src 'self' data: https://*.paypal.com https://www.paypalobjects.com https://*.tidio.co;
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
    font-src 'self' https://fonts.gstatic.com;
    frame-src https://www.paypal.com;
  Referrer-Policy: no-referrer-when-downgrade
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cache-Control: public, max-age=600

# API routes must never be cached — they return dynamic JSON responses and
# must be served fresh on every request.  This overrides the Cache-Control
# set by the /* rule above so that a cached error response (e.g. a prior 404
# from a misconfigured deployment) can never be served from CDN in place of
# the correct JSON API response.
/api/*
  Cache-Control: no-store, max-age=0
