{
  "name": "edunancial-site",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "curriculum:import": "node scripts/curriculum/import.mjs",
    "curriculum:validate": "node scripts/curriculum/validate.mjs",
    "curriculum:audit": "node scripts/curriculum/audit.mjs",
    "curriculum:locate": "node scripts/curriculum/locate.mjs",
    "curriculum:inventory": "node scripts/curriculum/inventory.mjs",
    "curriculum:migrate-legacy": "node scripts/curriculum/migrate-legacy.mjs",
    "curriculum:test": "node --test scripts/curriculum/tests/*.test.mjs",
    "international:test": "node --experimental-specifier-resolution=node --test scripts/international/tests/preferences.test.ts",
    "regionalization:test": "node --experimental-strip-types --test scripts/regionalization/tests/engine.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "rm -rf .test-dist && tsc -p tsconfig.test.json && node --test .test-dist/guardrails.test.js"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "next": "^15.5.19",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.20"
  }
}
